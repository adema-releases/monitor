# Copiar a .monitor.env y ajustar valores operativos.
# La identidad del nodo vive en /etc/adema/node.env y tiene prioridad para:
# ADEMA_NODE_ID, ADEMA_NODE_UUID, CLUSTER_ID, PROJECT_CODE, dominios y BACKUP_REMOTE.

PROJECT_CODE=demo
CLUSTER_ID=CLUSTER-DEMO-01

DB_PREFIX=demo
DB_NAME_PREFIX=demo_db
DB_USER_PREFIX=demo_user

VOLUME_BASE_PATH=/var/lib/docker/volumes
VOLUME_PREFIX=demo
VOLUME_FOLDERS="license logs media"

BACKUP_DIR=/var/lib/demo/backups_locales
BACKUP_RETENTION_DAYS=7
BACKUP_REMOTE=r2:demo-backups
RCLONE_CONFIG=/root/.config/rclone/rclone.conf
TENANT_ENV_DIR=/etc/adema/tenants
ADEMA_AUDIT_LOG=/var/log/adema-node/audit.jsonl
BASE_DOMAIN=example.com

BREVO_RECIPIENT=ops@example.com
BREVO_SENDER=no-reply@example.com
BREVO_SENDER_NAME="Adema Core Demo"

SECRETS_FILE=/root/.monitor_secrets

# DB_HOST puede omitirse para auto-deteccion de docker0.
DB_HOST=
DB_PORT=5432
RAM_THRESHOLD_MB=450
EXCLUDE_CONTAINER_REGEX="coolify|NAME"