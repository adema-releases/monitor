# Copiar a .monitor.env y ajustar valores

PROJECT_CODE=miapp
CLUSTER_ID=CLUSTER-MIAPP-01

DB_PREFIX=miapp
DB_NAME_PREFIX=miapp_db
DB_USER_PREFIX=user_miapp

VOLUME_BASE_PATH=/var/lib/docker/volumes
VOLUME_PREFIX=miapp
VOLUME_FOLDERS="license logs media"

BACKUP_DIR=/var/lib/miapp/backups_locales
BACKUP_RETENTION_DAYS=7
BACKUP_REMOTE=r2:miapp-backups

BREVO_RECIPIENT=ops@tuempresa.com
BREVO_SENDER=monitor@tuempresa.com
BREVO_SENDER_NAME="Adema Core Operaciones"

SECRETS_FILE=/root/.monitor_secrets

# DB_HOST puede omitirse para auto-deteccion de docker0.
DB_HOST=
DB_PORT=5432
RAM_THRESHOLD_MB=450
EXCLUDE_CONTAINER_REGEX="coolify|NAME"