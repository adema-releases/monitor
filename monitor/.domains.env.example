# Adema Core - Configuracion de dominios
# Copiar a /etc/adema/domains.env y ajustar valores
# O dejar que el asistente lo genere: sudo bash monitor/setup_domains.sh

# Dominio base del servidor (obligatorio)
ADEMA_BASE_DOMAIN=tudominio.com

# Subdominio para el panel Adema Core
# Default si se omite: infra.$ADEMA_BASE_DOMAIN
ADEMA_INFRA_DOMAIN=infra.tudominio.com

# Subdominio para Coolify
# Default si se omite: deploy.$ADEMA_BASE_DOMAIN
ADEMA_DEPLOY_DOMAIN=deploy.tudominio.com

# Puerto local del panel web (default: 5000)
ADEMA_PANEL_PORT=5000

# Bind local del panel web (default: 127.0.0.1)
# No cambiar a 0.0.0.0: el panel no debe estar expuesto publicamente
ADEMA_PANEL_BIND=127.0.0.1

# Puerto local de Coolify (default: 8000)
# Coolify escucha en 127.0.0.1:8000 por defecto
ADEMA_COOLIFY_PORT=8000
